// Quick orientation: the playground is wired and the runtime is alive.

std := import("std")
core := std.core

checks := [
    "nominal types for domain rules",
    "variants for explicit state",
    "recoverable runtime traps",
]

std.io.println("Gengo playground is live.")
std.io.printf("loaded %d showcase topics:\n", core.len(checks))
for i, check in checks {
    std.io.printf("  %d. %s\n", i + 1, check)
}

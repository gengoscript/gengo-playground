// Raw multiline text is useful for embedded config, SQL, and release notes.

std := import("std")

release_note :=
    \\service: playground
    \\change: mobile overhaul
    \\checks:
    \\  - tighter header layout
    \\  - clearer editor actions
    \\  - stacked mobile workspace

query :=
    \\select service, status
    \\from deployments
    \\where region = "eu-west"
    \\  and note = 'mobile rollout'

std.io.println(release_note)
std.io.println(query)
